{
  "name": "react-native-magic-tab-bar",
  "version": "2.1.0",
  "description": "Customizable floating tab bar for Expo Router and React Navigation (bare React Native). Bring your own icons and labels.",
  "workspaces": [
    "example"
  ],
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "source": "./src/index.tsx",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./default-tabs": {
      "types": "./lib/typescript/defaultTabs.d.ts",
      "default": "./lib/module/defaultTabs.js"
    },
    "./react-navigation": {
      "types": "./lib/typescript/reactNavigation.d.ts",
      "default": "./lib/module/reactNavigation.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/*.test.*",
    "!**/*.spec.*"
  ],
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc --noEmit",
    "example": "npm --prefix example run start"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-router",
    "react-navigation",
    "react-native-cli",
    "bottom-tabs",
    "bottom-tab-navigator",
    "tab-bar",
    "tabbar",
    "tabs",
    "floating-tab-bar",
    "animated-tab-bar",
    "custom-tab-bar",
    "navigation",
    "reanimated",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Bhavinpethani04/react-native-magic-tab-bar.git"
  },
  "homepage": "https://github.com/Bhavinpethani04/react-native-magic-tab-bar#readme",
  "bugs": {
    "url": "https://github.com/Bhavinpethani04/react-native-magic-tab-bar/issues"
  },
  "author": "Bhavin Pethani <pethanibhavin004@gmail.com>",
  "license": "MIT",
  "peerDependencies": {
    "@expo/vector-icons": "*",
    "@react-navigation/bottom-tabs": ">=6.0.0",
    "@react-navigation/native": ">=6.0.0",
    "expo": "*",
    "expo-glass-effect": ">=56.0.0",
    "expo-haptics": ">=56.0.0",
    "expo-router": ">=56.0.0",
    "react": "*",
    "react-native": "*",
    "react-native-reanimated": ">=3.0.0",
    "react-native-safe-area-context": ">=4.0.0",
    "react-native-worklets": "*"
  },
  "peerDependenciesMeta": {
    "@expo/vector-icons": {
      "optional": true
    },
    "@react-navigation/bottom-tabs": {
      "optional": true
    },
    "@react-navigation/native": {
      "optional": true
    },
    "expo": {
      "optional": true
    },
    "expo-router": {
      "optional": true
    },
    "react-native-worklets": {
      "optional": true
    },
    "expo-glass-effect": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@types/react": "~19.2.2",
    "del-cli": "^6.0.0",
    "react-native-builder-bob": "^0.40.0",
    "typescript": "~6.0.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
