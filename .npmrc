# npm workspaces + react-native-builder-bob example app:
# the root library declares loose peerDependencies ("*", ">=3.0.0"). Without this,
# npm installs its own newer copies of react/react-native/reanimated at the root,
# duplicating the example's exact-pinned versions -> "Invalid hook call" / worklet
# crashes. legacy-peer-deps keeps a single hoisted copy (the example's versions).
legacy-peer-deps=true
